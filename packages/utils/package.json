{
  "name": "@echo/utils",
  "version": "0.1.0",
  "description": "Shared utility functions",
  "main": "index.ts",
  "author": "Biswajit Malakar <mebiswajitmalakar@gmail.com>",
  "license": "ISC",
  "scripts": {
    "build": "rm -R -f ./dist && pnpm tsc",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./prompts": {
      "types": "./src/prompts/index.ts",
      "default": "./dist/prompts/index.js"
    },
    "./functions": {
      "types": "./src/functions/index.ts",
      "default": "./dist/functions/index.js"
    },
    "./models": {
      "types": "./src/models/index.ts",
      "default": "./dist/models/index.js"
    }
  },
  "devDependencies": {
    "@echo/types": "workspace:*",
    "@echo/typescript-config": "workspace:*",
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "echo",
    "utils",
    "functions"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.21.0"
  }
}