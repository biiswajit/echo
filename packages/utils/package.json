{
  "name": "@echo/utils",
  "version": "0.1.0",
  "description": "Shared utility functions",
  "main": "index.ts",
  "author": "Biswajit Malakar <mebiswajitmalakar@gmail.com>",
  "license": "ISC",
  "scripts": {
    "build": "pnpm tsc",
    "check-types": "tsc --noEmit",
    "dev": "pnpm tsc --watch"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./prompts": {
      "types": "./src/prompts/index.ts",
      "default": "./dist/prompts/index.js"
    }
  },
  "devDependencies": {
    "@echo/typescript-config": "workspace:*",
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "echo",
    "utils",
    "functions"
  ]
}