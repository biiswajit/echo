{
  "name": "@echo/types",
  "version": "0.1.0",
  "private": true,
  "description": "This package contains shared zod schemas and types",
  "author": "Biswajit Malakar <mebiswajitmalakar@gmail.com>",
  "license": "ISC",
  "scripts": {
    "build": "rm -R -f ./dist && pnpm tsc",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    "./typescript": {
      "types": "./src/typescript/index.ts",
      "default": "./dist/typescript/index.js"
    },
    "./zod": {
      "types": "./src/zod/index.ts",
      "default": "./dist/zod/index.js"
    }
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@echo/database": "workspace:*",
    "@echo/typescript-config": "workspace:*",
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "zod",
    "schema",
    "types"
  ]
}